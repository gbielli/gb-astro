  code: |
    const expectedValue = 'test';
    mockData.type = 'createOrUpdateProfile';
    mockData.customerProperties = [{ 'name': 'customproperty', 'value': expectedValue }];
    mockData.customerStandardProperties = [{ 'name': 'first_name', 'value': expectedValue }];
    mockData.customerLocationProperties = [{ 'name': 'address1', 'value': expectedValue }];
    mockData.klaviyoUserId = expectedValue;
    mockData.email = expectedValue;

    mock('sendHttpRequest', (url, callback, options, body) => {
      const bodyParsed = JSON.parse(body);
      assertThat(url).isEqualTo('https://a.klaviyo.com/api/profile-import/');
      assertThat(options.method).isEqualTo('POST');
      assertThat(bodyParsed.data.type).isEqualTo('profile');
      assertThat(bodyParsed.data.attributes.properties.customproperty).isEqualTo(expectedValue);
      assertThat(bodyParsed.data.attributes.email).isEqualTo(expectedValue);
      assertThat(bodyParsed.data.attributes.first_name).isEqualTo(expectedValue);
      assertThat(bodyParsed.data.attributes.location.address1).isEqualTo(expectedValue);
      assertThat(bodyParsed.data.id).isEqualTo(expectedValue);
    });

    runCode(mockData);
