---
const { title = "default title", question = "default question", message = "default message", underline = "default underline" } = Astro.props;
---

<div
  id="tracking-cta"
  class="w-full mx-auto bg-white border border-blue-100 rounded-xl p-8 overflow-hidden transition-shadow shadow-[0_0_0_4px_#eff6ff,0_4px_24px_0_rgba(59,130,246,0.06)]"
>
  <!-- Top blue bar -->
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-500 via-blue-400 to-blue-300 rounded-t-xl" />

  <!-- Dot grid background -->
  <div
    class="absolute inset-0 opacity-30 pointer-events-none"
    style="background-image: radial-gradient(#bfdbfe 1px, transparent 1px); background-size: 20px 20px;"
  />

  <div class="relative">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-200 rounded px-2.5 py-1 mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse" />
      <span class="font-mono text-[10px] font-semibold tracking-widest uppercase text-blue-500">
        {title}
      </span>
    </div>

    <!-- Subtitle -->
    <p class="text-sm mt-0 text-slate-500 leading-relaxed mb-6">
      <span class="text-blue-300">$ </span>
      <span class="text-blue-500 font-medium">ITP</span>
      <br />
    </p>

    <!-- Form -->
    <div id="cta-form">
      <div class="flex gap-2">
        <input
          id="cta-email"
          type="email"
          placeholder="votre@email.com"
          class="flex-1 px-3.5 py-2.5 border border-blue-100 rounded-lg bg-slate-50 text-sm text-slate-900 placeholder-slate-400 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 focus:bg-white"
        />
        <button
          id="cta-btn"
          disabled
          class="flex items-center gap-1.5 px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg transition-all shadow-[0_2px_8px_rgba(37,99,235,0.25)] hover:bg-blue-700 hover:shadow-[0_4px_16px_rgba(37,99,235,0.35)] hover:-translate-y-px active:translate-y-0 disabled:bg-blue-200 disabled:shadow-none disabled:cursor-default"
        >
          Envoyer
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>

      <p class="flex items-center gap-1.5 mt-3 text-xs text-slate-400">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
          <circle cx="6" cy="6" r="5" stroke="#94a3b8" stroke-width="1.2" />
          <path d="M6 5.5v3M6 4h.01" stroke="#94a3b8" stroke-width="1.2" stroke-linecap="round" />
        </svg>
        {underline}
      </p>
    </div>

    <!-- Success state (hidden by default) -->
    <div id="cta-success" class="hidden items-center gap-2.5 text-blue-600 text-sm font-mono">
      <span class="w-6 h-6 rounded-full bg-blue-50 border border-blue-200 flex items-center justify-center text-[11px]">
        ✓
      </span>
      C'est bien reçu !
    </div>
  </div>
</div>

<script>
  const input = document.getElementById("cta-email") as HTMLInputElement;
  const btn = document.getElementById("cta-btn") as HTMLButtonElement;
  const form = document.getElementById("cta-form") as HTMLDivElement;
  const success = document.getElementById("cta-success") as HTMLDivElement;

  input.addEventListener("input", () => {
    btn.disabled = !input.value.trim();
  });

  async function submit() {
    const email = input.value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = "...";

    const res = await fetch("/api/subscribe", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email }),
    });

    if (res.ok) {
      form.classList.add("hidden");
      success.classList.remove("hidden");
      success.classList.add("flex");
    } else {
      btn.disabled = false;
      btn.textContent = "Envoyer";
    }
  }

  btn.addEventListener("click", submit);

  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && input.value.trim()) submit();
  });
</script>